run_mode: "full"

platforms:
  - id: "weibo"
  - id: "douyin"
  - id: "zhihu"
  - id: "baidu"
  - id: "toutiao"
  - id: "bilibili"
  - id: "tieba"
  - id: "douban"

notification:
  serverchan:
    sendkey: ""     # 这里填你的SendKey

push:
  mode: "summary"
  max_items: 10
  show_images: false

ai_analysis:
  enabled: false

schedule:
  cron: "0 8,12,16,20 * * *"

dedup:
  enabled: true
  method: "memory"
  keep_recent: 200
